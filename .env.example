# Required
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL connection string (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/compliance_db

# Optional
DEBUG=false
GEMINI_MODEL=gemini-1.5-flash

# Security / API auth
# Comma-separated API keys accepted via the X-API-Key header. Leave empty to
# disable auth for local development (NOT recommended for production).
API_KEYS=

# Comma-separated list of allowed CORS origins (e.g. your frontend's URL).
CORS_ORIGINS=http://localhost:3000

# Database migrations
# Set to true in production and manage schema via `alembic upgrade head`
# instead of relying on auto create_all at startup.
USE_ALEMBIC_MIGRATIONS=false
